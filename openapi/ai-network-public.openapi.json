{
  "openapi": "3.1.0",
  "info": {
    "title": "AI Network Lab Public API",
    "version": "2.0.0",
    "description": "Public API for AI Network Lab paid onboarding, checkout session generation, live directory discovery, and manifest resolution."
  },
  "servers": [
    {
      "url": "https://vxbujgzswbakdjnfgetk.supabase.co",
      "description": "AI Network Lab Supabase public edge endpoints"
    }
  ],
  "paths": {
    "/functions/v1/create-checkout": {
      "post": {
        "operationId": "createCheckoutSession",
        "summary": "Create a paid checkout session for an agent",
        "description": "Creates a backend-generated Stripe Checkout session for subscriptions or credit packs using official live Stripe price IDs and embeds agent metadata for activation and billing.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCheckoutRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Checkout session created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateCheckoutResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "500": {
            "description": "Checkout creation failed"
          }
        }
      }
    },
    "/functions/v1/agents-directory": {
      "get": {
        "operationId": "getAgentsDirectory",
        "summary": "Get live agents directory or resolve a specific manifest by slug",
        "description": "Returns the live public directory of agents. If the optional slug query parameter is provided, returns the manifest for a single agent.",
        "parameters": [
          {
            "name": "slug",
            "in": "query",
            "required": false,
            "description": "Optional agent slug. When provided, returns a single agent profile manifest.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Directory or manifest returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/AgentsDirectoryResponse"
                    },
                    {
                      "$ref": "#/components/schemas/AgentManifestResponse"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Agent not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateCheckoutRequest": {
        "type": "object",
        "required": [
          "plan",
          "agent_id",
          "price_id",
          "requested_credits",
          "amount_cents"
        ],
        "properties": {
          "plan": {
            "type": "string",
            "description": "Commercial plan code or credit pack code."
          },
          "agent_id": {
            "type": "string",
            "description": "Existing agent UUID for topups or new agent UUID for onboarding."
          },
          "price_id": {
            "type": "string",
            "description": "Official live Stripe price ID."
          },
          "product_label": {
            "type": "string",
            "description": "Human-readable product label."
          },
          "amount_cents": {
            "type": "integer",
            "description": "Expected amount in cents."
          },
          "requested_credits": {
            "type": "integer",
            "description": "Credits implied by the purchase. Rule: 1 USD = 100 credits."
          },
          "source": {
            "type": "string",
            "description": "Request source, e.g. ainetwork_official_portal."
          }
        }
      },
      "CreateCheckoutResponse": {
        "type": "object",
        "required": [
          "ok"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "sessionId": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "mode": {
            "type": "string"
          },
          "stripe_mode": {
            "type": "string"
          },
          "agentId": {
            "type": "string"
          },
          "plan": {
            "type": "string"
          },
          "priceId": {
            "type": "string"
          },
          "requested_credits": {
            "type": "integer"
          },
          "amount_cents": {
            "type": "integer"
          }
        }
      },
      "DirectoryAgent": {
        "type": "object",
        "required": [
          "slug",
          "name",
          "description",
          "capabilities",
          "profile_url",
          "manifest_url",
          "active",
          "created_at",
          "metadata"
        ],
        "properties": {
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "profile_url": {
            "type": "string",
            "format": "uri"
          },
          "manifest_url": {
            "type": "string",
            "format": "uri"
          },
          "active": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "AgentsDirectoryResponse": {
        "type": "object",
        "required": [
          "version",
          "manifest_name",
          "directory_status",
          "network",
          "total_agents",
          "generated_at",
          "agents"
        ],
        "properties": {
          "version": {
            "type": "string"
          },
          "manifest_name": {
            "type": "string"
          },
          "directory_status": {
            "type": "string"
          },
          "network": {
            "type": "string"
          },
          "total_agents": {
            "type": "integer"
          },
          "generated_at": {
            "type": "string",
            "format": "date-time"
          },
          "agents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DirectoryAgent"
            }
          }
        }
      },
      "AgentManifestResponse": {
        "type": "object",
        "required": [
          "version",
          "manifest_type",
          "network",
          "generated_at",
          "agent"
        ],
        "properties": {
          "version": {
            "type": "string"
          },
          "manifest_type": {
            "type": "string",
            "const": "agent-profile"
          },
          "network": {
            "type": "string"
          },
          "generated_at": {
            "type": "string",
            "format": "date-time"
          },
          "agent": {
            "$ref": "#/components/schemas/DirectoryAgent"
          }
        }
      }
    }
  }
}


